# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# ingest raw-HTML cache (regenerable audit cache; large). The committed snapshot
# src/data/diputados.json IS the published data and stays tracked.
/data/raw/
/src/data/*.tmp

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
